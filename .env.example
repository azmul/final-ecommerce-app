# =============================================================================
# REQUIRED — set these before starting the app
# =============================================================================
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change_me_to_a_random_64_char_hex_string
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname

# =============================================================================
# Site configuration
# =============================================================================
COMPANY_NAME="My Company"
SITE_NAME="My Store"

# Public server URL (no trailing slash)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# =============================================================================
# Draft preview (change to a strong random value)
# =============================================================================
PREVIEW_SECRET=change_me_to_a_random_secret

# =============================================================================
# Stripe (set with live keys in production)
# =============================================================================
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_...

# =============================================================================
# Analytics (optional)
# =============================================================================
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# GA4_MEASUREMENT_ID=
# GA4_API_SECRET=
# NEXT_PUBLIC_META_PIXEL_ID=
# META_PIXEL_ID=
# META_CAPI_ACCESS_TOKEN=

# =============================================================================
# Klaviyo (optional)
# =============================================================================
# KLAVIYO_PRIVATE_API_KEY=
# KLAVIYO_LIST_ID=

# =============================================================================
# Web Push VAPID keys
# Run: npx web-push generate-vapid-keys
# =============================================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# =============================================================================
# AI shopping assistant (DeepSeek chat + optional embeddings for semantic search)
# =============================================================================
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# Optional embeddings provider for pgvector semantic search (OpenAI-compatible API)
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Cron secret — authorize /api/cron/* endpoints
# =============================================================================
CRON_SECRET=

# =============================================================================
# Email (SMTP)
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=orders@example.com

# =============================================================================
# Image uploads — optional AWS S3
# =============================================================================
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_PUBLIC_URL=
# S3_ACL=public-read
# S3_FORCE_PATH_STYLE=true
