PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=mongodb://127.0.0.1/template-ecommerce

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Store"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Facebook App ID — enables Messenger share (next-share FacebookMessengerShareButton).
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# Web Push — run `npx web-push generate-vapid-keys` and paste keys here.
# Use the same public key for NEXT_PUBLIC_VAPID_PUBLIC_KEY and VAPID_PUBLIC_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto or https URL identifying the sender (required by the Web Push protocol).
VAPID_SUBJECT=mailto:you@example.com

# Optional: authorize GET /api/cron/notifications (scheduled admin broadcasts).
# Example: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
