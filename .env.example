# =============================================================================
# REQUIRED — set these before starting the app
# =============================================================================
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change_me_to_a_random_64_char_hex_string
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname

# =============================================================================
# Site configuration
# =============================================================================
COMPANY_NAME="My Company"
SITE_NAME="My Store"

# Public server URL (no trailing slash)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# SEO / AISO (optional — used by manifest, JSON-LD, llms.txt)
# SITE_DESCRIPTION=Shop quality products online in Bangladesh with fast checkout and nationwide delivery.
# SITE_LOCALE=en-BD
# SITE_CURRENCY=BDT
# SITE_COUNTRY=BD
# SOCIAL_PROFILE_URLS=https://facebook.com/yourpage,https://instagram.com/yourpage
# CONTACT_EMAIL=hello@example.com
# CONTACT_PHONE=+8801XXXXXXXXX
# NEXT_PUBLIC_CONTACT_PHONE=+8801XXXXXXXXX

# =============================================================================
# Draft preview (change to a strong random value)
# =============================================================================
PREVIEW_SECRET=change_me_to_a_random_secret

# =============================================================================
# Stripe (set with live keys in production)
# =============================================================================
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_...

# =============================================================================
# Analytics (optional)
# =============================================================================
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ID=
# GA4_MEASUREMENT_ID=
# GA4_API_SECRET=
# NEXT_PUBLIC_META_PIXEL_ID=
# META_PIXEL_ID=
# META_CAPI_ACCESS_TOKEN=
# META_TEST_EVENT_CODE=
# META_DEBUG=1

# =============================================================================
# Search engine verification & IndexNow (optional)
# =============================================================================
# GOOGLE_SITE_VERIFICATION=
# BING_SITE_VERIFICATION=
# INDEXNOW_KEY=generate_8_to_128_hex_chars

# =============================================================================
# Klaviyo (optional)
# =============================================================================
# KLAVIYO_PRIVATE_API_KEY=
# KLAVIYO_LIST_ID=

# =============================================================================
# Web Push VAPID keys
# Run: npx web-push generate-vapid-keys
# =============================================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# =============================================================================
# AI shopping assistant + RAG (chat LLM + embeddings for semantic search)
# Provider priority: DeepSeek when DEEPSEEK_API_KEY is set, otherwise OpenRouter.
# =============================================================================

# --- Chat LLM (pick one provider) ---
# Recommended production setup: DeepSeek for chat + OpenAI for embeddings.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Default when DEEPSEEK_API_KEY is unset (OpenRouter free model is slow ~35–120s):
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_REQUEST_TIMEOUT_MS=120000
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_NAME=My Store

# --- Embeddings (required for semantic product search + RAG knowledge base) ---
# Use OpenAI text-embedding-3-small (1536d) — do not reuse chat keys unless OpenRouter supports embeddings.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# --- RAG index sync (after deploy or first AI setup) ---
# Option A — CLI (local or CI): pnpm migrate && pnpm sync:rag
# Option B — cron: curl -H "Authorization: Bearer $CRON_SECRET" "$NEXT_PUBLIC_SERVER_URL/api/cron/sync-knowledge-base"
# Option C — auto on server boot (dedicated Node host only; avoid on serverless):
# RAG_SYNC_ON_STARTUP=true

# RAG tuning (optional)
# RAG_MIN_SIMILARITY_SCORE=0.3
# RAG_DEFAULT_LIMIT=5
# RAG_CHUNK_MAX_CHARS=900

# =============================================================================
# Social login — Google & Facebook OAuth (optional)
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect URI: {NEXT_PUBLIC_SERVER_URL}/api/auth/google/callback
# Facebook: https://developers.facebook.com/apps/
#   Redirect URI: {NEXT_PUBLIC_SERVER_URL}/api/auth/facebook/callback
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# =============================================================================
# Loyalty points (optional overrides)
# =============================================================================
# LOYALTY_EARN_RATE=0.01
# LOYALTY_POINT_VALUE_BDT=1
# LOYALTY_MIN_REDEEM=50

# =============================================================================
# SMS / WhatsApp — Twilio (optional)
# =============================================================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# =============================================================================
# Referral program — points awarded on first delivered order from referred customer
# =============================================================================
# REFERRAL_REWARD_POINTS=200

# =============================================================================
# Cron secret — authorize /api/cron/* endpoints
# =============================================================================
CRON_SECRET=

# =============================================================================
# Email (SMTP)
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=orders@example.com

# =============================================================================
# Image uploads — optional AWS S3
# =============================================================================
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_PUBLIC_URL=
# S3_ACL=public-read
# S3_FORCE_PATH_STYLE=true
