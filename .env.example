PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=mongodb://127.0.0.1/template-ecommerce

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Store"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Facebook App ID — enables Messenger share (next-share FacebookMessengerShareButton).
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# --- Analytics & attribution (optional) ---
# GA4: browser tag + Measurement Protocol for server Purchase on order confirmation.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Meta: Pixel (browser) + Conversions API for server Purchase (same event_id as Pixel Purchase if you add it client-side).
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Klaviyo: subscribe Payload form-builder submissions that include an email field.
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_LIST_ID=

# Web Push — run `npx web-push generate-vapid-keys` and paste keys here (URL-safe base64, no "=" padding).
# Use the same public key for NEXT_PUBLIC_VAPID_PUBLIC_KEY and VAPID_PUBLIC_KEY. Do not swap public/private.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto or https URL identifying the sender (required by the Web Push protocol).
VAPID_SUBJECT=mailto:you@example.com

# Optional: authorize GET /api/cron/notifications (scheduled admin broadcasts).
# Example: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
