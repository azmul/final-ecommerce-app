{
  "name": "my-project",
  "version": "1.0.0",
  "description": "Ecommerce template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env PAYLOAD_MIGRATION_NON_INTERACTIVE=true NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:db-schema": "cross-env NODE_OPTIONS=--no-deprecation payload generate:db-schema",
    "generate:pwa-icons": "node ./scripts/generate-pwa-icons.mjs",
    "verify:migration-coverage": "node ./scripts/verify-migration-coverage.mjs",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lighthouse:report": "NPM_CONFIG_CACHE=/tmp/npm-cache pnpm dlx lighthouse http://localhost:3000 --only-categories=performance,accessibility,best-practices,seo --output=html --output-path=./lighthouse-report.html --chrome-flags=\"--headless --no-sandbox\"",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "migrate": "cross-env PAYLOAD_MIGRATION_NON_INTERACTIVE=true NODE_OPTIONS=--no-deprecation payload migrate",
    "sync:rag": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm scripts/sync-rag-index.mjs",
    "backfill:risk": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm scripts/backfill-risk-scores.mjs",
    "cleanup:logs": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm scripts/cleanup-logs.mjs",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env PAYLOAD_MIGRATION_NON_INTERACTIVE=true NODE_OPTIONS=--no-deprecation next start",
    "stripe-webhooks": "stripe listen --forward-to localhost:3000/api/payments/stripe/webhooks",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=--no-deprecation vitest run tests/int/seedFrontendCatalog.int.spec.ts && cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@payloadcms/admin-bar": "3.85.1",
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/email-nodemailer": "3.85.1",
    "@payloadcms/live-preview-react": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/plugin-ecommerce": "3.85.1",
    "@payloadcms/plugin-form-builder": "3.85.1",
    "@payloadcms/plugin-seo": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-s3": "^3.85.1",
    "@payloadcms/translations": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@radix-ui/react-accordion": "1.2.14",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@sentry/nextjs": "^10.58.0",
    "@stripe/react-stripe-js": "^6",
    "@stripe/stripe-js": "^9.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.2",
    "graphql": "^17.0.0",
    "jsonwebtoken": "9.0.3",
    "lucide-react": "1.20.0",
    "next": "16.2.9",
    "next-seo": "^7.2.0",
    "next-share": "^0.27.0",
    "next-themes": "0.4.6",
    "payload": "3.85.1",
    "prism-react-renderer": "^2.4.1",
    "qs-esm": "8.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "react-player": "^3.4.0",
    "sharp": "0.35.1",
    "sonner": "^2.0.7",
    "stripe": "22.2.1",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/react": "16.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "@vercel/git-hooks": "^1.0.0",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "nodemailer@<9.0.1": "^9.0.1",
      "undici@<7.28.0": "^7.28.0",
      "ws@<8.21.0": "^8.21.0",
      "fast-uri@<3.1.2": "^3.1.2"
    }
  }
}
